{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push origin main)",
      "Bash(git push -u origin *)",
      "Bash(git merge --ff-only*)",
      "Bash(git worktree*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git stash*)",

      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm test*)",
      "Bash(npm run build*)",
      "Bash(npm run test:e2e*)",
      "Bash(npm run loop:pick*)",

      "Bash(npx tsc*)",
      "Bash(npx vitest*)",
      "Bash(npx playwright*)",
      "Bash(npx wrangler*)",
      "Bash(npx ccusage*)",
      "Bash(npx --yes ccusage*)",

      "Bash(node scripts/loop/*)",

      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin --delete*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf *)",
      "Bash(wrangler pages deploy*)",
      "Bash(npx wrangler pages deploy*)",
      "Bash(wrangler secret*)",
      "Bash(npx wrangler secret*)",

      "Read(.dev.vars)",
      "Read(.dev.vars.*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
